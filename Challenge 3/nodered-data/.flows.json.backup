    {
        "id": "b5dc3c321c481233",
        "type": "function",
        "z": "c2a9723ca23517ee",
        "name": "Format id_log.csv",
        "func": "var counter = (global.get('logCounter') || 0) + 1;\nglobal.set('logCounter', counter);\nvar data = (typeof msg.payload === 'string') ? JSON.parse(msg.payload) : msg.payload;\nvar line = (counter === 1 ? 'No.,ID,TIMESTAMP\\n' : '') +\n           counter + ',' + data.id + ',' + data.timestamp + '\\n';\nmsg.payload = line;\nmsg.filename = '/challenge3/id_log.csv';\nreturn msg;",
        "outputs": 1,
        "x": 690,
        "y": 240,
        "wires": [
